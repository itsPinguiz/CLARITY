{
    "name": "SemEval-2026 CLARITY Environment",
    "build": {
        "dockerfile": "Dockerfile",
        "context": "..",
        "args": {
            "USERNAME": "vscode"
        }
    },
    // CRITICAL: GPU Passthrough Configuration
    // Requires NVIDIA Container Toolkit on host
    "runArgs": [
        "--gpus",
        "all"
    ],
    "remoteUser": "vscode",
    "features": {
        // Pre-install standard dev tools
        "ghcr.io/devcontainers/features/common-utils:2": {
            "installZsh": true,
            "username": "vscode"
        },
        // Ensure Git credentials forward from host to container
        "ghcr.io/devcontainers/features/git:1": {}
    },
    // Configure VS Code extensions to auto-install inside the container
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-python.vscode-pylance",
                "ms-toolsai.jupyter",
                "njpwerner.autodocstring",
                "donjayamanne.githistory",
                "mechatroner.rainbow-csv",
                "usernamehw.errorlens"
            ],
            "settings": {
                "python.defaultInterpreterPath": "/home/vscode/venv/bin/python",
                "python.formatting.provider": "black",
                "editor.formatOnSave": true,
                "notebook.formatOnSave.enabled": true
            }
        }
    },
    // Validation command to run after container starts
    // Verifies that GPU is visible and accessible
    "postCreateCommand": "nvidia-smi && python -c 'import torch; print(f\"CUDA Available: {torch.cuda.is_available()}\")'"
}